#!/usr/bin/env bash
# claude-deck — modo remoto en un comando. `deck help` explica el uso completo.
set -euo pipefail

# NUNCA como root: launchctl bootstrap de un dominio gui falla corriendo como
# root ("Domain does not support specified action"); el sudo que hace falta
# (sudoers/pmset) el script lo pide solo, puntualmente.
if [ "$(id -u)" = "0" ]; then
  printf '❌ no corras esto con sudo — corrélo como tu usuario; el script pide sudo solo cuando lo necesita\n' >&2
  exit 1
fi

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LABEL="com.claude-deck"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG="$HOME/Library/Logs/claude-deck.log"
SUDOERS_FILE="/etc/sudoers.d/claude-deck"
GUI="gui/$(id -u)"

# el server ignora PORT a propósito; el puerto real sale de DECK_PORT en .env
PORT="$(grep -m1 '^DECK_PORT=' "$REPO/.env" 2>/dev/null | cut -d= -f2 || true)"
PORT="${PORT:-7433}"

info() { printf '%s\n' "$*"; }
warn() { printf '⚠️  %s\n' "$*"; }
die()  { printf '❌ %s\n' "$*" >&2; exit 1; }

server_alive() {
  # cualquier código HTTP (401 sin token incluido) = server vivo; 000 = nada escuchando
  [ "$(curl -m 3 -so /dev/null -w '%{http_code}' "http://127.0.0.1:$PORT/api/config" 2>/dev/null || true)" != "000" ]
}

agent_loaded() { launchctl print "$GUI/$LABEL" >/dev/null 2>&1; }

serve_url() {
  # primera línea de `tailscale serve status`: "https://host.tailnet.ts.net (tailnet only)"
  tailscale serve status 2>/dev/null | awk 'NR==1 && $1 ~ /^https/ { print $1 }'
}

# guarda DECK_URL en .env para el deep-link de notify.sh (header Click del
# push → PWA con la sesión seleccionada). Se re-escribe sola si cambió el
# hostname del tailnet (basta re-correr install/away/url).
persist_deck_url() {
  local url cur
  url="$(serve_url)"
  [ -n "$url" ] || return 0
  [ -f "$REPO/.env" ] || return 0
  cur="$(grep -m1 '^DECK_URL=' "$REPO/.env" | cut -d= -f2- || true)"
  [ "$cur" = "$url" ] && return 0
  if grep -q '^DECK_URL=' "$REPO/.env"; then
    sed -i '' "s|^DECK_URL=.*|DECK_URL=$url|" "$REPO/.env"
  else
    printf 'DECK_URL=%s\n' "$url" >> "$REPO/.env"
  fi
  info "✓ DECK_URL guardada en .env ($url) — los push llevan deep-link a la sesión"
}

# configura `tailscale serve` si falta (es persistente: una sola vez). Devuelve
# 1 con warn si tailscale no está instalado/conectado — el panel queda solo local
ensure_serve() {
  if ! command -v tailscale >/dev/null 2>&1; then
    warn "tailscale no está instalado (https://tailscale.com/download) — el panel queda solo local"
    return 1
  fi
  if ! tailscale status --json 2>/dev/null | grep -q '"BackendState": "Running"'; then
    warn "tailscale no está conectado — abrí la app de Tailscale (o corré: tailscale up) y repetí"
    return 1
  fi
  if [ -z "$(serve_url)" ]; then
    if tailscale serve --bg "$PORT" >/dev/null 2>&1; then
      info "✓ tailscale serve configurado (queda persistente): puerto $PORT expuesto solo a tu tailnet"
    else
      warn "no pude configurar tailscale serve — corré a mano: tailscale serve --bg $PORT"
      return 1
    fi
  fi
  persist_deck_url
}

token_from_env() { grep -m1 '^AUTH_TOKEN=' "$REPO/.env" 2>/dev/null | cut -d= -f2; }

cmd_url() {
  local url token full
  url="$(serve_url)"
  if [ -z "$url" ]; then
    ensure_serve || die "sin tailscale serve no hay URL para el teléfono"
    url="$(serve_url)"
    [ -n "$url" ] || die "tailscale serve no reporta URL — probá: tailscale serve status"
  fi
  persist_deck_url
  token="$(token_from_env)"
  [ -n "$token" ] || die "no encuentro AUTH_TOKEN en $REPO/.env"
  full="$url/?token=$token"
  info "URL para el teléfono (la primera visita deja cookie: después no hace falta el token):"
  info ""
  info "  $full"
  info ""
  if command -v qrencode >/dev/null 2>&1; then
    qrencode -t ANSIUTF8 "$full"
    info "Escaneala con la cámara del teléfono y agregá la PWA con «Add to Home Screen»."
  else
    info "tip: brew install qrencode → deck url muestra un QR escaneable con la cámara"
  fi
}

# --- exponer apps locales al tailnet (tarea 35) -----------------------------
# `deck expose <puerto>` publica localhost:<puerto> en el tailnet por HTTPS,
# como una SEGUNDA entrada de `tailscale serve` en un puerto externo igual al
# local (https://<host>.<tailnet>.ts.net:<puerto>/). Coexiste con la del panel
# (443 -> 7433) sin tocarla, así que serve_url()/persist_deck_url() (que leen la
# línea 1) siguen viendo el panel. No es un proxy: tailscale hace el forward, la
# raíz queda en `/` y no se reescribe ningún path (por eso las SPAs andan). A
# diferencia del panel, la app NO queda detrás del AUTH_TOKEN: la única frontera
# es el tailnet (WireGuard). Persistente hasta `deck unexpose <puerto>`.

# tailscale instalado + conectado, sin configurar el serve del panel (expose/
# unexpose solo agregan o quitan entradas de serve por puerto).
tailscale_ready() {
  command -v tailscale >/dev/null 2>&1 || { warn "tailscale no está instalado (https://tailscale.com/download)"; return 1; }
  tailscale status --json 2>/dev/null | grep -q '"BackendState": "Running"' \
    || { warn "tailscale no está conectado (abrí la app de Tailscale o: tailscale up)"; return 1; }
}

valid_port() { case "$1" in ''|*[!0-9]*) return 1 ;; esac; [ "$1" -ge 1 ] && [ "$1" -le 65535 ]; }

# URLs del status con puerto explícito = las de `deck expose` (la del panel va en
# 443, sin puerto en la URL). Una por línea: https://<host>:<puerto>
exposed_urls() {
  tailscale serve status 2>/dev/null | grep -oE '^https://[^ ]+:[0-9]+'
}

cmd_expose() {
  local port="${1:-}"
  if [ -z "$port" ]; then
    local urls; urls="$(exposed_urls || true)"
    if [ -z "$urls" ]; then
      info "no hay apps expuestas."
      info "uso: deck expose <puerto>     (p. ej. deck expose 5173)"
      return 0
    fi
    info "apps locales expuestas al tailnet (las ve solo tu tailnet; NO van tras el AUTH_TOKEN):"
    local u
    while IFS= read -r u; do info "  $u/"; done <<<"$urls"
    info ""
    info "bajar una: deck unexpose <puerto>"
    return 0
  fi
  valid_port "$port" || die "puerto inválido: '$port' (usá 1-65535)"
  [ "$port" = "$PORT" ] && die "el puerto $port es el del panel (DECK_PORT); ya está publicado con 'deck url'"
  tailscale_ready || die "sin tailscale conectado no puedo exponer nada"
  if ! nc -z 127.0.0.1 "$port" 2>/dev/null; then
    warn "nada escucha en localhost:$port todavía (lo expongo igual: arrancá la app cuando quieras)"
  fi
  tailscale serve --bg --https="$port" "localhost:$port" >/dev/null 2>&1 \
    || die "no pude exponer $port (probá a mano: tailscale serve --bg --https=$port localhost:$port)"
  local full; full="$(exposed_urls | grep ":$port\$" | head -1 || true)"
  full="${full:+$full/}"
  info "✓ localhost:$port expuesto al tailnet, persistente hasta 'deck unexpose $port':"
  info ""
  info "  ${full:-https://<tu-host>.ts.net:$port/}"
  info ""
  warn "lo ve cualquier dispositivo de tu tailnet y NO está tras el AUTH_TOKEN del panel (WireGuard es la única frontera)."
  info "   si es un dev server (Vite/Storybook/Next) y entrás por el hostname, habilitá el host-check:"
  info "     Vite/Storybook →  server.allowedHosts: true   (solo en dev)"
  if command -v qrencode >/dev/null 2>&1 && [ -n "$full" ]; then
    info ""
    qrencode -t ANSIUTF8 "$full"
  fi
}

cmd_unexpose() {
  local port="${1:-}"
  [ -n "$port" ] || die "uso: deck unexpose <puerto>     ('deck expose' sin args lista los que hay)"
  valid_port "$port" || die "puerto inválido: '$port' (usá 1-65535)"
  tailscale_ready || die "sin tailscale no puedo tocar los mapeos"
  if ! exposed_urls | grep -q ":$port\$"; then
    warn "el puerto $port no figura expuesto ('deck expose' lista los que hay); igual intento bajarlo"
  fi
  tailscale serve --https="$port" off >/dev/null 2>&1 \
    || die "no pude bajar el puerto $port (probá a mano: tailscale serve --https=$port off)"
  info "✓ localhost:$port ya no está expuesto al tailnet"
}

sleep_disabled() { pmset -g 2>/dev/null | awk '/SleepDisabled/ { print $2; found=1 } END { if (!found) print 0 }'; }

on_ac() { pmset -g batt 2>/dev/null | head -1 | grep -q 'AC Power'; }

pm_sleep() { # pm_sleep 1|0 → disablesleep on/off (sudoers de `deck install` evita el password)
  if ! sudo -n /usr/bin/pmset -a disablesleep "$1" 2>/dev/null; then
    if [ -t 0 ]; then
      info "(sudo te va a pedir el password — \`deck install\` configura sudoers para que no haga falta)"
      sudo /usr/bin/pmset -a disablesleep "$1"
    else
      die "sudo necesita password y no hay terminal interactiva: corré \`scripts/deck install\` una vez"
    fi
  fi
}

wait_for_server() {
  for _ in $(seq 1 20); do
    server_alive && return 0
    sleep 0.5
  done
  return 1
}

write_plist() {
  local node_bin node_dir
  node_bin="$(command -v node)" || die "no encuentro node en el PATH"
  node_dir="$(dirname "$node_bin")"
  mkdir -p "$(dirname "$PLIST")" "$(dirname "$LOG")"
  # node directo sobre el cli de tsx (sin shebang de por medio); PATH incluye el
  # bin de node (nvm) y homebrew para que el server encuentre tmux/git/osascript
  cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$node_bin</string>
    <string>$REPO/node_modules/tsx/dist/cli.mjs</string>
    <string>$REPO/server/index.ts</string>
  </array>
  <key>WorkingDirectory</key><string>$REPO</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>$node_dir:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>LANG</key><string>en_US.UTF-8</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$LOG</string>
  <key>StandardErrorPath</key><string>$LOG</string>
</dict>
</plist>
EOF
  plutil -lint "$PLIST" >/dev/null || die "plist inválido: $PLIST"
}

install_sudoers() {
  local tmp u
  tmp="$(mktemp)"
  # OJO: bajo `sudo deck install`, $USER/id -un son root y la regla quedaría
  # para root (inútil: root no necesita NOPASSWD y el usuario real queda sin
  # regla; pasó de verdad, tarea 36). SUDO_USER recupera al usuario que invocó.
  u="${SUDO_USER:-$(id -un)}"
  [ "$u" = "root" ] && die "no corras deck install como root de verdad: la regla sudoers debe ser para tu usuario"
  printf '%s ALL=(root) NOPASSWD: /usr/bin/pmset -a disablesleep 1, /usr/bin/pmset -a disablesleep 0\n' "$u" > "$tmp"
  visudo -cf "$tmp" >/dev/null || { rm -f "$tmp"; die "regla sudoers inválida (bug del script)"; }
  if sudo -n true 2>/dev/null || [ -t 0 ]; then
    sudo install -o root -g wheel -m 0440 "$tmp" "$SUDOERS_FILE"
    info "✓ sudoers configurado ($SUDOERS_FILE): pmset disablesleep sin password"
  else
    warn "no pude configurar sudoers sin terminal interactiva — corré \`scripts/deck install\` de nuevo en tu terminal"
  fi
  rm -f "$tmp"
}

cmd_install() {
  [ -f "$REPO/.env" ] || die "falta $REPO/.env (el server no arranca sin AUTH_TOKEN)"
  write_plist
  info "✓ LaunchAgent escrito ($PLIST)"
  install_sudoers
  if server_alive && ! agent_loaded; then
    warn "ya hay un server en el puerto $PORT (¿tu \`npm run dev\` manual?)."
    warn "cuando lo cierres, corré \`scripts/deck start\` — desde ahí el agente lo mantiene siempre corriendo"
  else
    cmd_start
  fi
  if ensure_serve; then
    info ""
    cmd_url
  fi
  info ""
  info "tip: alias deck='$REPO/scripts/deck'   (agregalo a tu ~/.zshrc)"
}

cmd_start() {
  [ -f "$PLIST" ] || die "no está instalado: corré \`scripts/deck install\`"
  if agent_loaded; then
    launchctl bootout "$GUI/$LABEL" 2>/dev/null || true
    # el unload es asincrónico: bootstrapear enseguida da "Input/output error"
    for _ in $(seq 1 20); do
      agent_loaded || break
      sleep 0.5
    done
    agent_loaded && die "no pude descargar el agente anterior — esperá unos segundos y probá de nuevo"
  fi
  local i out=''
  for i in 1 2 3 4 5; do
    out="$(launchctl bootstrap "$GUI" "$PLIST" 2>&1)" && break
    if [ "$i" = 5 ]; then
      die "launchctl bootstrap falló 5 veces: ${out:-sin detalle}"
    fi
    sleep 1 # launchd a veces tarda en soltar el label recién descargado
  done
  if wait_for_server; then
    info "✓ server corriendo (agente launchd, puerto $PORT)"
  else
    die "el agente no levantó el server — mirá el log: scripts/deck log"
  fi
}

cmd_stop() {
  launchctl bootout "$GUI/$LABEL" 2>/dev/null || warn "el agente no estaba cargado"
  info "✓ agente parado — el puerto $PORT queda libre (para volver: scripts/deck start)"
}

cmd_away() {
  # 1. server
  if ! server_alive; then
    if agent_loaded; then
      launchctl kickstart -k "$GUI/$LABEL"
      wait_for_server || die "no pude levantar el server — mirá el log: scripts/deck log"
    else
      cmd_start # bootstrap robusto; muere con mensaje claro si no está instalado
    fi
  fi
  if ! agent_loaded; then
    warn "el server corre a mano (¿npm run dev?): si esa terminal se cierra, se muere."
    warn "para que quede siempre corriendo: scripts/deck install"
  fi
  # 2. tailscale (config persistente: verificar de punta a punta, configurando serve si falta)
  local url
  url="$(serve_url)"
  if [ -z "$url" ]; then
    ensure_serve || true
    url="$(serve_url)"
  fi
  if [ -z "$url" ]; then
    warn "sin tailscale serve el panel queda solo local — corré: tailscale serve --bg $PORT"
  elif [ "$(curl -m 6 -so /dev/null -w '%{http_code}' "$url/api/config" 2>/dev/null || true)" = "000" ]; then
    warn "$url no responde — ¿tailscale caído? probá: tailscale up"
  else
    info "✓ accesible desde el tailnet: $url"
  fi
  # 3. energía
  on_ac || warn "estás a BATERÍA: tapa cerrada + despierta come batería en serio — enchufala"
  pm_sleep 1
  [ "$(sleep_disabled)" = "1" ] || die "pmset no quedó aplicado (SleepDisabled != 1)"
  info "✓ la Mac no va a dormir ni con la tapa cerrada"
  info ""
  info "🚀 listo, cerrá la tapa y seguí desde el celu. Al volver: scripts/deck back"
}

cmd_back() {
  pm_sleep 0
  [ "$(sleep_disabled)" = "0" ] || die "pmset no quedó aplicado (SleepDisabled != 0)"
  info "✓ sueño normal restaurado (el server sigue corriendo, eso no gasta nada)"
}

cmd_status() {
  server_alive && info "server:    ✓ vivo (127.0.0.1:$PORT)" || info "server:    ✗ no responde"
  agent_loaded && info "agente:    ✓ cargado ($LABEL)" || info "agente:    ✗ no cargado"
  local url; url="$(serve_url)"
  [ -n "$url" ] && info "tailscale: ✓ $url" || info "tailscale: ✗ serve sin configurar"
  [ "$(sleep_disabled)" = "1" ] && info "sueño:     despierta con tapa cerrada (modo away)" || info "sueño:     normal"
  info "energía:   $(pmset -g batt 2>/dev/null | tail -1 | sed 's/^[[:space:]]*//' || echo '?')"
}

cmd_log() { touch "$LOG"; tail -n 50 -f "$LOG"; }

# --- lanzar Claude Code adentro de una sesión tmux visible en el panel -------

# nombre de sesión tmux derivado del directorio actual, ajustado a lo que el
# server acepta (SESSION_RE: [A-Za-z0-9_-]{1,32}, sufijo -shell reservado). La
# cuenta de trabajo (ccw) suma sufijo -work para NO colisionar con la default
# (cc) en el mismo repo: sin eso, correr ccw donde ya vive una sesión cc solo
# attacheaba a la de cc en vez de abrir la de trabajo aparte.
session_name_for_dir() { # $1 = directorio, $2 = cuenta (work | vacío) → nombre válido
  local n suf=''
  [ "${2:-}" = work ] && suf='-work'
  n="$(printf '%s' "$(basename "$1")" | sed 's/[^A-Za-z0-9_-]/-/g' | cut -c1-$((32 - ${#suf})))"
  case "$n" in *-shell) n="${n%-shell}-s" ;; esac
  printf '%s' "${n:-deck}$suf"
}
session_name_for_cwd() { session_name_for_dir "$PWD" "${1:-}"; }

cmd_launch() { # $1 = alias/comando a tipear en el pane (cc | ccw), resto = flags
  # dentro de tmux no se anida un attach: ahí el comando se corre directo
  [ -n "${TMUX:-}" ] && die "ya estás adentro de una sesión tmux — corré '$*' directo"
  local name acct=''
  [ "$1" = ccw ] && acct=work   # ccw = cuenta de trabajo: sesión aparte de cc
  name="$(session_name_for_cwd "$acct")"
  if ! tmux has-session -t "=$name" 2>/dev/null; then
    tmux new-session -d -s "$name" -c "$PWD"
    info "✓ sesión tmux '$name' creada — ya aparece como chip en el panel del celu"
    # se tipea el ALIAS, no su expansión: el pane corre tu zsh interactivo (con
    # tu ~/.zshrc cargado), así cc/ccw significan lo mismo acá y en tu terminal
    tmux send-keys -t "=$name:" "$*" Enter
  else
    # sesión del mismo directorio ya viva: attach. Si quedó en el shell (claude
    # cerrado o recién reiniciada la Mac), relanzar el comando pedido.
    local pane_cmd
    pane_cmd="$(tmux display-message -p -t "=$name:" '#{pane_current_command}' 2>/dev/null || true)"
    case "$pane_cmd" in
      zsh|bash|sh) tmux send-keys -t "=$name:" "$*" Enter
                   info "✓ sesión '$name' estaba en el shell: relanzando '$*'" ;;
      *)           info "✓ attach a '$name' (ya hay algo corriendo: no se relanza nada)" ;;
    esac
  fi
  exec tmux attach -t "=$name"
}

# seguir en la Mac una sesión del deck (las que arrancás desde el celu ya existen
# como sesiones tmux planas: dispatch/worktree hacen `tmux new-session -d`, y el
# panel attachea con `-A`). `deck attach <nombre>` engancha directo; sin nombre,
# lista las vivas y elegís. Adentro de otro tmux no se anida un attach: se usa
# `switch-client`. El nombre es el mismo que ves como chip de sesión en el panel.
cmd_attach() { # $1 = nombre de sesión tmux (opcional); sin nombre → menú
  local name="${1:-}"
  # dentro de tmux no se anida attach: se cambia de sesión del cliente actual
  local verb='attach'
  [ -n "${TMUX:-}" ] && verb='switch-client'
  if [ -z "$name" ]; then
    local sessions arr=() i=0 s
    sessions="$(tmux list-sessions -F '#S' 2>/dev/null || true)"
    [ -n "$sessions" ] || die "no hay sesiones tmux vivas (arrancá una desde el celu, o acá con \`deck cc\`)"
    info "sesiones tmux vivas:"
    while IFS= read -r s; do
      i=$((i + 1)); arr+=("$s")
      printf '  %d) %s\n' "$i" "$s"
    done <<< "$sessions"
    if [ "$i" = 1 ]; then
      name="${arr[0]}"
      info "→ una sola: $verb a '$name'"
    else
      [ -t 0 ] || die "pasá el nombre: \`deck attach <nombre>\` (sin terminal interactiva no hay menú)"
      local pick
      printf 'elegí (número o nombre): '
      read -r pick || die "cancelado"
      if printf '%s' "$pick" | grep -Eq '^[0-9]+$' && [ "$pick" -ge 1 ] && [ "$pick" -le "$i" ]; then
        name="${arr[$((pick - 1))]}"
      else
        name="$pick"
      fi
    fi
  fi
  tmux has-session -t "=$name" 2>/dev/null || die "no existe la sesión '$name' (mirá las vivas con \`deck attach\` a secas, o \`tmux ls\`)"
  exec tmux "$verb" -t "=$name"
}

# escalón 3 del spike de adopción (tarea 37): que `cc`/`ccw` NUNCA queden
# huérfanos de tmux. Imprime funciones de shell para sourcear con
#   eval "$(deck shellinit)"
# en el ~/.zshrc (reemplazan a los aliases `cc`/`ccw`). La lógica vive acá, en
# el repo, así el zshrc solo la sourcea y los clonadores la heredan. La función
# corre claude directo cuando NO tiene sentido envolver (ya adentro de tmux, uso
# no interactivo por pipe/script, o `-p`/`--print`), y si no delega a `deck
# cc`/`deck ccw`, que crean/attachean la sesión tmux del cwd. Sin recursión: el
# `deck cc` tipea `cc` en el pane, que ya está en tmux, cae a claude directo.
cmd_shellinit() {
  # ruta absoluta del propio deck: el `deck` del usuario suele ser un alias (no
  # está en PATH), así que la función no puede usar `command deck`.
  printf '# claude-deck: cc/ccw siempre adentro de tmux (tarea 37). Generado por `deck shellinit`.\n'
  printf '__DECK_BIN=%q\n' "$REPO/scripts/deck"
  cat <<'EOF'
__deck_is_print() {
  local a
  for a in "$@"; do
    case "$a" in -p|--print) return 0 ;; esac
  done
  return 1
}
__deck_claude() { # $1 = perfil (cc|ccw), resto = flags de claude
  local prof="$1"; shift
  if [ -n "${TMUX:-}" ] || [ ! -t 0 ] || [ ! -t 1 ] || __deck_is_print "$@"; then
    # no tiene sentido envolver: claude directo, respetando la cuenta del perfil
    if [ "$prof" = ccw ]; then
      CLAUDE_CONFIG_DIR="$HOME/.claude-work" command claude "$@"
    else
      command claude "$@"
    fi
  else
    # interactivo y fuera de tmux: que nazca adentro de tmux (visible en el celu)
    "$__DECK_BIN" "$prof" "$@"
  fi
}
cc()  { __deck_claude cc  "$@"; }
ccw() { __deck_claude ccw "$@"; }
EOF
}

# --- adoptar una sesión huérfana (escalón 2 del spike, tarea 37) -------------
# Una sesión huérfana es un `claude` interactivo vivo FUERA de tmux (típico: la
# terminal integrada de VS Code): el panel no la ve porque el deck sigue
# sesiones tmux. `deck adopt` la rescata suave: espera a que termine el turno en
# curso, cierra limpio el huérfano y relanza `claude --continue` dentro de una
# sesión tmux del mismo cwd. Se preserva la conversación entera; solo se pierde
# el turno en vuelo. No se reparenta el proceso vivo: en macOS es imposible
# (ver docs/SPIKE-adopt.md; glosario en CONTEXT.md: "sesión huérfana", "adoptar").
DECK_ADOPT_PROC="${DECK_ADOPT_PROC:-claude}"   # comm a cazar; override solo para tests
DECK_ADOPT_DEBOUNCE="${DECK_ADOPT_DEBOUNCE:-2}" # seg sin escribir el .jsonl para creer "idle"

# ttys ocupadas por panes de tmux, normalizadas a ttysNNN (ps no antepone /dev/)
_adopt_tmux_ttys() { tmux list-panes -a -F '#{pane_tty}' 2>/dev/null | sed 's#^/dev/##'; }

# cwd (directorio de trabajo) de un pid
_adopt_pid_cwd() { lsof -a -d cwd -p "$1" -Fn 2>/dev/null | sed -n 's/^n//p' | head -1; }

# cuenta del huérfano: "work" si su entorno trae CLAUDE_CONFIG_DIR=...claude-work
# (el alias ccw), si no "" (cuenta por defecto). ps -E vuelca el env de procesos
# propios en macOS.
_adopt_pid_account() {
  ps -wwwE -o command= -p "$1" 2>/dev/null | tr ' ' '\n' \
    | grep -q 'CLAUDE_CONFIG_DIR=[^ ]*claude-work' && printf 'work'
}

_adopt_acct_label() { case "$1" in work) printf 'ccw' ;; *) printf 'cc' ;; esac; }

# raíz de transcripts según la cuenta ("" = default, "work" = ~/.claude-work)
_adopt_projects_root() {
  case "$1" in
    work) printf '%s/.claude-work/projects' "$HOME" ;;
    *)    printf '%s/.claude/projects' "$HOME" ;;
  esac
}

# slug de proyecto de Claude Code: el cwd con '/' y '.' a '-' (verificado mirando
# ~/.claude*/projects). El '.cwd' del propio .jsonl confirma el match, así que el
# slug es solo el camino rápido, no una apuesta.
_adopt_slug() { printf '%s' "$1" | sed 's#[/.]#-#g'; }

# .jsonl más reciente del cwd/cuenta cuyo campo .cwd confirma el directorio
_adopt_transcript() { # $1=cwd $2=account → stdout: ruta del .jsonl (o falla)
  local dir f
  dir="$(_adopt_projects_root "$2")/$(_adopt_slug "$1")"
  [ -d "$dir" ] || return 1
  for f in $(ls -1t "$dir"/*.jsonl 2>/dev/null); do
    grep -qF "\"cwd\":\"$1\"" "$f" 2>/dev/null && { printf '%s' "$f"; return 0; }
  done
  return 1
}

# estado de un huérfano leyendo su transcript: "idle <edad>" | working | unknown.
# Señal FIABLE: el último evento portador de turno REAL del .jsonl. assistant con
# stop_reason distinto de tool_use (y no nulo) = turno terminado = idle; un user,
# o un assistant tool_use/parcial = working. Filtramos isMeta/isSidechain: los
# slash commands locales (/rename, etc.) y el modo away dejan eventos de cola
# (custom-title, system, y un user con isMeta:true) DESPUES del último turno real;
# sin filtrarlos, ese user meta se leería como el último portador de turno y daría
# un falso "working" sobre una sesión idle. Además exigimos que el archivo no se
# haya tocado en los últimos DECK_ADOPT_DEBOUNCE seg (si sigue creciendo hay
# streaming = working), lo que de paso cubre la carrera de leer una última línea
# a medio escribir. Se descartó la heurística de proceso (CPU/hijos): da
# falso-idle cuando claude espera la respuesta del modelo por red (sin CPU ni
# subprocesos pero trabajando), justo el caso en que adoptar pierde el turno.
_adopt_state() { # $1=cwd $2=account
  local f verdict now m age
  [ -n "$1" ] || { printf 'unknown'; return; }
  f="$(_adopt_transcript "$1" "$2")" || { printf 'unknown'; return; }
  verdict="$(jq -rc 'select((.type=="assistant" or .type=="user") and (.isMeta != true) and (.isSidechain != true))
      | if .type=="user" then "working"
        elif (.message.stop_reason=="tool_use" or .message.stop_reason==null) then "working"
        else "idle" end' "$f" 2>/dev/null | tail -1)"
  [ -n "$verdict" ] || { printf 'unknown'; return; }
  now="$(date +%s)"; m="$(stat -f %m "$f" 2>/dev/null || echo "$now")"; age=$((now - m))
  if [ "$verdict" = idle ] && [ "$age" -ge "$DECK_ADOPT_DEBOUNCE" ]; then
    printf 'idle %ss' "$age"
  else
    printf 'working'
  fi
}

# huérfanos, "pid|tty|account|cwd" por línea. Huérfano = comm claude, con tty
# real (no '??' = no daemon/host), cuya tty NO está en ningún pane de tmux.
_adopt_orphans() {
  local tmux_ttys p tty
  tmux_ttys="$(_adopt_tmux_ttys)"
  for p in $(pgrep -x "$DECK_ADOPT_PROC" 2>/dev/null); do
    tty="$(ps -o tty= -p "$p" 2>/dev/null | tr -d ' ')"
    case "$tty" in ''|'?'|'??') continue ;; esac
    printf '%s\n' "$tmux_ttys" | grep -qxF "$tty" && continue
    printf '%s|%s|%s|%s\n' "$p" "$tty" "$(_adopt_pid_account "$p")" "$(_adopt_pid_cwd "$p")"
  done
}

_adopt_row() { # $1=n $2=pid $3=account $4=cwd $5=state
  printf '  %d) %s (%s)  pid %s  [%s]\n' "$1" "${4:-<cwd desconocido>}" "$(_adopt_acct_label "$3")" "$2" "$5"
}

# polea hasta idle mostrando progreso; Ctrl-C aborta (el trap de cmd_adopt limpia)
_adopt_wait_idle() { # $1=cwd $2=account
  local st
  while :; do
    st="$(_adopt_state "$1" "$2")"
    case "$st" in
      idle*)   printf '\n'; info "✓ el turno terminó (idle)"; return 0 ;;
      unknown) printf '\n'; warn "perdí la señal del transcript; sigo esperando el idle..." ;;
    esac
    printf '.'
    sleep "$DECK_ADOPT_DEBOUNCE"
  done
}

# nombre de sesión tmux LIBRE para el cwd. Si el base ya existe (p. ej. ya
# adoptaste otro claude del mismo repo, o tenés una sesión viva ahí), prueba
# base-2, base-3, etc. Nunca reusa una sesión existente: cada huérfano adoptado
# es un claude aparte y tipearlo en la sesión de otro lo rompería. Respeta el
# SESSION_RE del server ({1,32}): recorta el base para que quepa el sufijo.
_adopt_free_name() { # $1 = cwd, $2 = cuenta (work|vacío) → stdout: nombre de sesión libre
  local base cand suf n=2
  base="$(session_name_for_dir "$1" "${2:-}")"
  tmux has-session -t "=$base" 2>/dev/null || { printf '%s' "$base"; return; }
  while :; do
    suf="-$n"
    cand="$(printf '%s' "$base" | cut -c1-$((32 - ${#suf})))$suf"
    tmux has-session -t "=$cand" 2>/dev/null || { printf '%s' "$cand"; return; }
    n=$((n + 1))
  done
}

# relanza claude --continue en una sesión tmux del cwd (fire-and-forget: no
# attachea, queda como chip en el celu). Comando crudo (no cc/ccw): no depende de
# que el usuario tenga esas funciones y adentro de tmux claude directo ya es
# visible en el panel.
_adopt_relaunch() { # $1=cwd $2=account
  local name cmd
  name="$(_adopt_free_name "$1" "$2")"
  if [ "$2" = work ]; then
    cmd="CLAUDE_CONFIG_DIR=$HOME/.claude-work claude --continue"
  else
    cmd="claude --continue"
  fi
  tmux new-session -d -s "$name" -c "$1"
  tmux send-keys -t "=$name:" "$cmd" Enter
  info "✓ adoptada: sesión tmux '$name' corriendo '$cmd'"
  info "  seguila del celu (ya aparece como chip) o en la Mac con: deck attach $name"
}

cmd_adopt() {
  command -v lsof >/dev/null 2>&1 || die "necesito lsof para ver el cwd de los huérfanos"
  local orphans; orphans="$(_adopt_orphans)"
  if [ -z "$orphans" ]; then
    info "no hay sesiones huérfanas: todo claude interactivo vivo ya está en tmux (o no hay ninguno)."
    info "para no crear huérfanos, arrancá con \`deck cc\`/\`deck ccw\` o instalá \`deck shellinit\`."
    return 0
  fi

  local pids=() accts=() cwds=() states=() i=0 p tty acct cwd
  while IFS='|' read -r p tty acct cwd; do
    [ -n "$p" ] || continue
    i=$((i + 1))
    pids+=("$p"); accts+=("$acct"); cwds+=("$cwd")
    states+=("$(_adopt_state "$cwd" "$acct")")
  done <<< "$orphans"

  local sel
  if [ "$i" = 1 ]; then
    sel=0
    info "sesión huérfana encontrada:"
    _adopt_row 1 "${pids[0]}" "${accts[0]}" "${cwds[0]}" "${states[0]}"
    [ -t 0 ] || die "sin terminal interactiva no confirmo la adopción (corré \`deck adopt\` en tu terminal)"
    local yn; printf '¿adoptar esta sesión? [s/N] '; read -r yn || die "cancelado"
    case "$yn" in s|S|si|Si|SI|y|Y) ;; *) info "cancelado, no toqué nada."; return 0 ;; esac
  else
    info "sesiones huérfanas (claude interactivo fuera de tmux):"
    local k
    for k in $(seq 0 $((i - 1))); do
      _adopt_row $((k + 1)) "${pids[$k]}" "${accts[$k]}" "${cwds[$k]}" "${states[$k]}"
    done
    [ -t 0 ] || die "sin terminal interactiva no hay menú (corré \`deck adopt\` en tu terminal)"
    local pick; printf 'elegí (número, o Enter para cancelar): '; read -r pick || die "cancelado"
    [ -n "$pick" ] || { info "cancelado."; return 0; }
    printf '%s' "$pick" | grep -Eq '^[0-9]+$' && [ "$pick" -ge 1 ] && [ "$pick" -le "$i" ] \
      || die "elección inválida: '$pick'"
    sel=$((pick - 1))
  fi

  local pid="${pids[$sel]}" account="${accts[$sel]}" cwddir="${cwds[$sel]}" state="${states[$sel]}"
  [ -n "$cwddir" ] || die "no pude resolver el cwd del pid $pid (¿lsof sin permiso?): no adopto a ciegas"

  # Ctrl-C durante la espera aborta sin haber tocado nada todavía
  trap 'printf "\n"; info "cancelado (no se tocó ninguna sesión)."; exit 130' INT

  case "$state" in
    idle*) : ;;
    working)
      info "la sesión está trabajando: espero a que termine el turno (Ctrl-C para cancelar)..."
      _adopt_wait_idle "$cwddir" "$account" ;;
    *)
      warn "no pude leer el estado (idle/working) de esta sesión desde su transcript."
      local yn2; printf '¿adoptar igual? PUEDE perder el turno en curso [s/N] '
      read -r yn2 || die "cancelado"
      case "$yn2" in s|S|si|Si|SI|y|Y) ;; *) info "cancelado."; return 0 ;; esac ;;
  esac

  trap - INT

  # cerrar limpio el huérfano ANTES de relanzar: nunca dos claude sobre el mismo history
  info "cerrando el huérfano (pid $pid) limpio..."
  kill -TERM "$pid" 2>/dev/null || true
  local g
  for g in $(seq 1 20); do kill -0 "$pid" 2>/dev/null || break; sleep 0.5; done
  kill -0 "$pid" 2>/dev/null \
    && die "el huérfano (pid $pid) no cerró tras SIGTERM; no relanzo para no duplicar sesión: cerralo a mano y reintentá"

  _adopt_relaunch "$cwddir" "$account"
}
# --- fin adoptar -------------------------------------------------------------

cmd_uninstall() {
  pm_sleep 0 2>/dev/null || true
  launchctl bootout "$GUI/$LABEL" 2>/dev/null || true
  rm -f "$PLIST"
  if sudo -n true 2>/dev/null || [ -t 0 ]; then
    sudo rm -f "$SUDOERS_FILE"
  else
    warn "no pude borrar $SUDOERS_FILE sin terminal interactiva — borralo con sudo a mano"
  fi
  info "✓ agente y sudoers removidos; el sueño quedó normal"
}

usage() {
  cat <<'EOF'
claude-deck — modo remoto en un comando

Para trabajar desde el celu hacen falta tres cosas: el server corriendo,
Tailscale sirviéndolo y la Mac despierta con la tapa cerrada. Tailscale queda
configurado para siempre y el server arranca solo con la Mac — lo único que
cambia día a día es el sueño, y para eso son `away` y `back`.

UNA SOLA VEZ:
  deck install    Deja el server instalado como servicio de macOS (arranca al
                  prender la Mac, se relevanta solo si se cae), configura el
                  permiso de sueño sin password y el tailscale serve, y muestra
                  la URL del teléfono. Después, olvidate de esto.
  deck url        URL del panel con token (+ QR si tenés qrencode instalado):
                  escaneás con la cámara del teléfono e instalás la PWA.

USO DIARIO (lo único que importa):
  deck cc [flags]   Lanza TU claude (alias cc, cuenta propia) adentro de una
                    sesión tmux nombrada según el directorio actual — se ve al
                    instante como chip en el celu. Mismo look que correr cc
                    directo; los flags van a claude: deck cc --continue
  deck ccw [flags]  Ídem con tu alias ccw (plan del trabajo).
  deck claude [flags]
                    Ídem corriendo claude directo (la variante sin alias, por
                    si no tenés cc/ccw definidos).
                    Si la sesión del directorio ya existe, attachea (y si claude
                    no está corriendo ahí, lo relanza).
  deck attach [nombre]
                    Seguir en la Mac una sesión que arrancaste desde el celu (o
                    cualquier sesión tmux del deck). Con nombre, attachea directo;
                    sin nombre, lista las vivas y elegís. El nombre es el mismo
                    que ves como chip de sesión en el panel. Adentro de otro tmux
                    cambia de sesión en vez de anidar (switch-client).
  deck adopt        Rescata una sesión huérfana: un claude interactivo que quedó
                    fuera de tmux (p. ej. arrancado a secas en la terminal de VS
                    Code) y por eso el panel no ve. Lista los huérfanos con su
                    cwd y estado; con uno solo confirma sí/no (nunca mata sin
                    confirmar). Si está trabajando espera a que termine el turno
                    (Ctrl-C cancela), lo cierra limpio y relanza claude
                    --continue en una sesión tmux del mismo directorio: se
                    conserva la conversación entera, solo se pierde el turno en
                    vuelo. Mejor no crear huérfanos: mirá deck shellinit.
  deck away         "Me voy": chequea que todo ande y deja la Mac despierta.
                    Cerrás la tapa (¡enchufada!) y seguís desde el celu.
  deck back         "Volví": la Mac vuelve a dormir normalmente.

  deck shellinit    Imprime funciones cc/ccw que SIEMPRE arrancan en tmux (para
                    seguirlas del celu sin que queden huérfanas). Sourcealo una
                    vez en tu ~/.zshrc, reemplazando los aliases cc/ccw:
                        eval "$(deck shellinit)"
                    Adentro de tmux, en pipes/scripts o con -p/--print corre
                    claude directo; interactivo y fuera de tmux, lo mete en una
                    sesión tmux del directorio actual.

ABRIR OTRAS APPS LOCALES EN EL CELU (dev servers, dashboards):
  deck expose <puerto>
                  Publica localhost:<puerto> en tu tailnet por HTTPS y te da la
                  URL (+ QR). Ej: arrancás Vite en 5173 y `deck expose 5173` lo
                  abre desde el celu. Sin puerto, lista lo que hay expuesto.
                  Ojo: la app la ve cualquier dispositivo de tu tailnet y NO
                  queda tras el AUTH_TOKEN del panel (la protege solo el tailnet).
                  Dev servers (Vite/Storybook): poné allowedHosts: true en dev.
  deck unexpose <puerto>
                  Baja ese mapeo (es persistente hasta que lo bajes).

SI ALGO ANDA RARO:
  deck status     ¿Server vivo? ¿agente cargado? ¿tailscale? ¿sueño? ¿batería?
  deck log        Ver el log del server en vivo (attaches, kills, errores).

SOLO PARA DESARROLLAR claude-deck (el servicio no tiene watch):
  deck stop       Apaga el servicio y libera el puerto → npm run dev
  deck start      Al terminar, le devolvés el server al servicio.

Y SI UN DÍA NO LO QUERÉS MÁS:
  deck uninstall  Saca servicio + permisos y restaura el sueño.

Tips: nunca lo corras con sudo (pide sudo solo cuando hace falta). Alias cómodo
para tu ~/.zshrc:  alias deck='<repo>/scripts/deck'
EOF
}

case "${1:-}" in
  install)        cmd_install ;;
  away)           cmd_away ;;
  back)           cmd_back ;;
  status)         cmd_status ;;
  start)          cmd_start ;;
  stop)           cmd_stop ;;
  log)            cmd_log ;;
  url)            cmd_url ;;
  expose)         shift; cmd_expose "$@" ;;
  unexpose)       shift; cmd_unexpose "$@" ;;
  uninstall)      cmd_uninstall ;;
  cc|ccw|claude)  cmd_launch "$@" ;;
  attach)         shift; cmd_attach "$@" ;;
  adopt)          cmd_adopt ;;
  shellinit)      cmd_shellinit ;;
  help|--help|-h) usage ;;
  *)              usage; exit 1 ;;
esac
