# claude-deck — configuración
# Copiar a .env y completar:  cp .env.example .env

# Perímetro de seguridad (obligatoria): raíz que contiene tus proyectos.
# El server NO lee archivos ni opera git fuera de esta ruta, sin importar a
# dónde haga cd una sesión tmux. Elegila tan amplia como necesites, a conciencia.
WORKSPACES_ROOT=/Users/tu-usuario/proyectos

# Directorio "home" del panel (default: WORKSPACES_ROOT): dónde nacen las
# sesiones tmux nuevas y sobre qué operan los endpoints sin ?session=.
# Debe estar dentro de WORKSPACES_ROOT.
#DEFAULT_DIR=/Users/tu-usuario/proyectos/mi-repo

# Token de acceso (obligatorio, ≥32 caracteres). Generar con:
#   openssl rand -hex 32
AUTH_TOKEN=

# Nombre de la sesión tmux de Claude (default: deck)
#TMUX_SESSION=deck

# Puerto local (default: 7433). El server bindea SOLO a 127.0.0.1.
# Se llama DECK_PORT y no PORT a propósito: los perfiles de shell suelen
# exportar PORT y las variables de entorno reales le ganan al .env.
#DECK_PORT=7433
