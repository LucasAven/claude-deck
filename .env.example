# claude-deck — configuración
# Copiar a .env y completar:  cp .env.example .env

# Ruta absoluta del repo a monitorear (obligatoria)
REPO_DIR=/Users/tu-usuario/proyectos/mi-repo

# Token de acceso (obligatorio, ≥32 caracteres). Generar con:
#   openssl rand -hex 32
AUTH_TOKEN=

# Nombre de la sesión tmux de Claude (default: deck)
#TMUX_SESSION=deck

# Puerto local (default: 7433). El server bindea SOLO a 127.0.0.1.
# Se llama DECK_PORT y no PORT a propósito: los perfiles de shell suelen
# exportar PORT y las variables de entorno reales le ganan al .env.
#DECK_PORT=7433

# Raíz permitida para repos de sesiones multi-tmux (default: directorio padre de REPO_DIR).
# Los endpoints git con ?session= solo operan en repos dentro de esta ruta.
#WORKSPACES_ROOT=/Users/tu-usuario/proyectos

# (Bonus) Topic secreto de ntfy.sh para notificaciones push cuando Claude te necesita.
# Generar algo largo y difícil de adivinar:  openssl rand -hex 16
#NTFY_TOPIC=
