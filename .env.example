# claude-deck — configuración
# Copiar a .env y completar:  cp .env.example .env

# Perímetro de blast-radius (obligatoria): lista de raíces con tus proyectos,
# separadas por ":" (como PATH). El server NO lee archivos ni opera git fuera de
# la UNION de estas rutas, sin importar a dónde haga cd una sesión tmux. No es
# confinamiento del usuario (la terminal tmux da un shell libre): acota el alcance
# de un bug en los lectores no-shell. Ver docs/adr/0002. Elegilas a conciencia.
WORKSPACES_ROOTS=/Users/tu-usuario/proyectos:/Users/tu-usuario/work

# Alias de compat (una sola raíz): solo se lee si WORKSPACES_ROOTS no está seteada.
#WORKSPACES_ROOT=/Users/tu-usuario/proyectos

# Directorio "home" del panel (default: la primera raíz): dónde nacen las
# sesiones tmux nuevas y sobre qué operan los endpoints sin ?session=.
# Debe estar dentro de alguna raíz del perímetro.
#DEFAULT_DIR=/Users/tu-usuario/proyectos/mi-repo

# Token de acceso (obligatorio, ≥32 caracteres). Generar con:
#   openssl rand -hex 32
AUTH_TOKEN=

# Nombre de la sesión tmux de Claude (default: deck)
#TMUX_SESSION=deck

# Puerto local (default: 7433). El server bindea SOLO a 127.0.0.1.
# Se llama DECK_PORT y no PORT a propósito: los perfiles de shell suelen
# exportar PORT y las variables de entorno reales le ganan al .env.
#DECK_PORT=7433
