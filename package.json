{
  "name": "claude-deck",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Panel remoto móvil (PWA) para sesiones locales de Claude Code vía tmux + Tailscale",
  "scripts": {
    "dev": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "puppeteer-core": "^25.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
